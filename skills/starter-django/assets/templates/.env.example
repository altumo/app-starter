# =============================================================================
# Django Backend
# =============================================================================

# Django secret key - generate with: python3 -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=REPLACE_ME_WITH_RANDOM_SECRET

# Comma-separated list of allowed hosts
ALLOWED_HOSTS=localhost,127.0.0.1

# Database URL (docker-compose overrides this, but useful for local dev without Docker)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/__PROJECT_NAME__

# =============================================================================
# Clerk Authentication (Backend)
# =============================================================================

# Clerk JWKS URL for JWT verification (Django uses this to verify Clerk JWTs)
# Format: https://<your-instance>.clerk.accounts.dev/.well-known/jwks.json
CLERK_JWKS_URL=https://REPLACE_ME.clerk.accounts.dev/.well-known/jwks.json

# Comma-separated list of authorized origins (must match your frontend URLs)
CLERK_AUTHORIZED_PARTIES=http://localhost:3000

# =============================================================================
# PostgreSQL
# =============================================================================

POSTGRES_DB=__PROJECT_NAME__
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# =============================================================================
# Ports (optional - override defaults)
# =============================================================================

# BACKEND_PORT=8000
# FRONTEND_PORT=3000
# DB_PORT=5432

# =============================================================================
# Production Only
# =============================================================================

# CORS_ALLOWED_ORIGINS=https://yourdomain.com
